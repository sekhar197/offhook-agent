# dependencies
node_modules/

# build output
dist/
build/
*.tsbuildinfo

# environment & secrets — never commit keys
.env
.env.*
!.env.example

# logs & runtime
*.log
logs/
coverage/

# OS / editor / tooling
.DS_Store
.idea/
.vscode/
.claude/

# local model caches
.cache/

# call observability records (the default jsonl sink target)
call-records.jsonl
*.call-records.jsonl

# generated eval scorecard (regenerate with a capable judge for launch)
docs/scorecard.md
docs/usecases.md

# self-improvement run artifacts (scorecard + audit trail)
improve/

# packed npm tarballs
*.tgz

# mutation-testing output (Stryker)
reports/
.stryker-tmp/

# local telephony state (provisioned number/trunk/dispatch IDs)
.offhook-agent/
